Attribute VB_Name = "A00_インストール"
'==============================================================
' A00_インストール ： 最初に1回だけ実行するモジュール
'
' ■つかいかた
'   すべての .bas ファイル（A00〜A10）をVBAエディタでインポートしたら、
'   Alt+F8 → 「初期設定」 → 実行 を1回だけ行ってください。
'   「メニュー」シートに、各機能を呼び出すボタンが自動で並びます。
'   （ボタンを押すだけで使えるようになり、以後Alt+F8は不要です）
'==============================================================
Option Explicit

Public Sub 初期設定()
    Dim ws As Worksheet
    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets("メニュー")
    On Error GoTo 0
    If ws Is Nothing Then
        MsgBox "「メニュー」シートが見つかりません。アシスタントブックで実行してください。", vbCritical
        Exit Sub
    End If

    '前に作ったボタンがあれば一度すべて消す（作り直しできるように）
    Dim btn As Object
    For Each btn In ws.Buttons
        btn.Delete
    Next btn

    'ボタンを縦に並べる（位置はセルに合わせる）
    Call ボタン設置(ws, "B4", "① 名簿を解析して照合する", "名簿を解析して照合する")
    Call ボタン設置(ws, "B6", "② クラス替えをマスターに反映する", "クラス替えをマスターに反映する")
    Call ボタン設置(ws, "B8", "③ 新入生としてマスターに登録する", "新入生としてマスターに登録する")
    Call ボタン設置(ws, "E4", "④ 支出をマスターへ一括入力", "支出をマスターへ一括入力")
    Call ボタン設置(ws, "E6", "⑤ 収入をマスターへ一括入力", "収入をマスターへ一括入力")
    Call ボタン設置(ws, "E8", "⑥ 収入枠の一覧を表示", "収入枠の一覧を表示")
    Call ボタン設置(ws, "H4", "⑦ 決算用の集計を実行", "決算用の集計を実行")
    Call ボタン設置(ws, "H6", "⑧ マスターの整合性をチェック", "マスターの整合性をチェック")
    Call ボタン設置(ws, "H8", "⑨ 精算書を一括PDF保存", "精算書を一括PDF保存")
    Call ボタン設置(ws, "H10", "⑩ 精算書を一括印刷", "精算書を一括印刷")
    Call ボタン設置(ws, "E10", "⑪ 振替結果を照合", "振替結果を照合")
    Call ボタン設置(ws, "E12", "⑫ 予定を入力フォームへ転送", "予定を入力フォームへ転送")

    MsgBox "初期設定が完了しました。「メニュー」シートのボタンから各機能を使えます。" & vbCrLf & vbCrLf & _
           "最初に「設定」シートに、マスターファイルの場所（C3）と年度（C5）を入力してください。", _
           vbInformation, "初期設定の完了"
End Sub

'--------------------------------------------------------------
' 指定セルの位置にマクロ実行ボタンを1つ置く
'--------------------------------------------------------------
Private Sub ボタン設置(ws As Worksheet, セル As String, 表示名 As String, マクロ名 As String)
    Dim rng As Range
    Set rng = ws.Range(セル)
    Dim btn As Object
    Set btn = ws.Buttons.Add(rng.Left, rng.Top, 180, 28)
    btn.Caption = 表示名
    btn.OnAction = マクロ名
    btn.Font.Size = 10
End Sub
